#include <iostream>
#include <string>
using namespace std;

struct Nodo {
    string idAsistente;
    string zonaAcceso;
    int horaIngreso;
    int factor_balance;
    Nodo* izq;
    Nodo* der;
    Nodo* padre;

    Nodo(string id, string zona, int hora)
        : idAsistente(id), zonaAcceso(zona), horaIngreso(hora),
          factor_balance(0), izq(nullptr), der(nullptr), padre(nullptr) {}
};

class ArbolAVL {
private:
    Nodo* raiz;

    Nodo* insertarRecursivo(Nodo* nodo, string id, string zona, int hora);
    int calcularAltura(Nodo* nodo);
    void actualizarFactor(Nodo* nodo);
    Nodo* rebalance(Nodo* nodo);
    Nodo* rotarIzquierda(Nodo* nodo);
    Nodo* rotarDerecha(Nodo* nodo);
    void mostrarEchado(Nodo* nodo, int nivel);

    // Función que compara las zonas en el orden deseado (VIP > Preferencial > Tribuna > General)
    int compararZonas(const string& zona1, const string& zona2) {
        if (zona1 == "VIP" && zona2 != "VIP") return -1;
        if (zona1 == "Preferencial" && (zona2 == "Tribuna" || zona2 == "General")) return -1;
        if (zona1 == "Tribuna" && zona2 == "General") return -1;
        if (zona1 == zona2) return 0;
        return 1; // Devolver 1 si zona1 es "General" y zona2 es diferente
    }

public:
    ArbolAVL() : raiz(nullptr) {}

    void insertar(string id, string zona, int hora);
    void mostrar();
};

// Función para insertar un nuevo nodo en el árbol
void ArbolAVL::insertar(string id, string zona, int hora) {
    raiz = insertarRecursivo(raiz, id, zona, hora);
}

// Inserción recursiva en el árbol AVL, comparando hora y zona
Nodo* ArbolAVL::insertarRecursivo(Nodo* nodo, string id, string zona, int hora) {
    if (!nodo) {
        return new Nodo(id, zona, hora);
    }

    // Crear la clave combinada: primero hora y luego zona
    string claveNueva = to_string(hora) + zona;  // Ejemplo: "10VIP"
    string claveActual = to_string(nodo->horaIngreso) + nodo->zonaAcceso;

    // Comparar las claves combinadas
    if (claveNueva < claveActual) {
        nodo->izq = insertarRecursivo(nodo->izq, id, zona, hora);
        nodo->izq->padre = nodo;
    } else if (claveNueva > claveActual) {
        nodo->der = insertarRecursivo(nodo->der, id, zona, hora);
        nodo->der->padre = nodo;
    } else {
        // Si la clave combinada es la misma, comparar por zona utilizando la función personalizada
        if (compararZonas(zona, nodo->zonaAcceso) < 0) {
            nodo->izq = insertarRecursivo(nodo->izq, id, zona, hora);
            nodo->izq->padre = nodo;
        } else {
            nodo->der = insertarRecursivo(nodo->der, id, zona, hora);
            nodo->der->padre = nodo;
        }
    }

    // Actualizar el factor de balance y rebalancear el árbol si es necesario
    actualizarFactor(nodo);
    return rebalance(nodo);
}

// Calcular la altura de un nodo
int ArbolAVL::calcularAltura(Nodo* nodo) {
    if (!nodo) return 0;
    return 1 + max(calcularAltura(nodo->izq), calcularAltura(nodo->der));
}

// Actualizar el factor de balance de un nodo
void ArbolAVL::actualizarFactor(Nodo* nodo) {
    nodo->factor_balance = calcularAltura(nodo->izq) - calcularAltura(nodo->der);
}

// Rebalancear el árbol si es necesario
Nodo* ArbolAVL::rebalance(Nodo* nodo) {
    actualizarFactor(nodo);
    if (nodo->factor_balance > 1) {
        if (nodo->izq && nodo->izq->factor_balance < 0) {
            nodo->izq = rotarIzquierda(nodo->izq);
        }
        return rotarDerecha(nodo);
    }

    if (nodo->factor_balance < -1) {
        if (nodo->der && nodo->der->factor_balance > 0) {
            nodo->der = rotarDerecha(nodo->der);
        }
        return rotarIzquierda(nodo);
    }

    return nodo;
}

// Rotar el árbol hacia la izquierda
Nodo* ArbolAVL::rotarIzquierda(Nodo* nodo) {
    Nodo* nuevaRaiz = nodo->der;
    nodo->der = nuevaRaiz->izq;
    if (nuevaRaiz->izq) nuevaRaiz->izq->padre = nodo;

    nuevaRaiz->izq = nodo;
    nuevaRaiz->padre = nodo->padre;
    nodo->padre = nuevaRaiz;

    actualizarFactor(nodo);
    actualizarFactor(nuevaRaiz);

    return nuevaRaiz;
}

// Rotar el árbol hacia la derecha
Nodo* ArbolAVL::rotarDerecha(Nodo* nodo) {
    Nodo* nuevaRaiz = nodo->izq;
    nodo->izq = nuevaRaiz->der;
    if (nuevaRaiz->der) nuevaRaiz->der->padre = nodo;

    nuevaRaiz->der = nodo;
    nuevaRaiz->padre = nodo->padre;
    nodo->padre = nuevaRaiz;

    actualizarFactor(nodo);
    actualizarFactor(nuevaRaiz);

    return nuevaRaiz;
}


void ArbolAVL::mostrar() {
    if (!raiz) {
        cout << "El árbol está vacío." << endl;
        return;
    }
    mostrarEchado(raiz, 0);
}


void ArbolAVL::mostrarEchado(Nodo* nodo, int nivel) {
    if (nodo) {
        mostrarEchado(nodo->der, nivel + 1);
        for (int i = 0; i < nivel; i++) cout << "    ";
        cout << nodo->idAsistente << " (" << nodo->zonaAcceso << ", " << nodo->horaIngreso << ", Factor Balance: " << nodo->factor_balance << ")\n";
        mostrarEchado(nodo->izq, nivel + 1);
    }
}

int main() {
    ArbolAVL arbol;

    // Insertando nodos en el árbol
    arbol.insertar("A123", "VIP", 10);
    arbol.insertar("B456", "Preferencial", 10);
    arbol.insertar("C789", "Tribuna", 10);
    arbol.insertar("D012", "General", 10);
    arbol.insertar("E345", "VIP", 11);
    arbol.insertar("F678", "General", 12);

    // Mostramos el árbol
    cout << "Árbol AVL (Visualizado):" << endl;
    arbol.mostrar();

    return 0;
}
